# ============================================================
# public/.htaccess - mod_rewrite para el front controller
# Apache sirve este directorio como raiz de /url-shortener/
# Todo lo que no sea archivo real va a index.php
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /url-shortener/

    # No reescribir archivos existentes (css, js, imagenes)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Todo lo demas va al front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

Options -Indexes
